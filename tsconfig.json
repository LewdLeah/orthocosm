{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "rootDir": ".",
    "declaration": true
  },
  "include": [
    "functions/**/*.ts",
    "steps/**/*.ts",
    "types/**/*.ts",
    "runtime/**/*.ts",
    "scripts/**/*.ts",
    "tests/**/*.ts",
    "main.ts"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}
